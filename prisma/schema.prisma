// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Get a free hosted Postgres database in seconds: `npx create-db`

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  createdAt DateTime @default(now())
}

model PaidUser {
  clerkUserId    String    @id
  paidAt         DateTime  @default(now())
  ceuAccessUntil DateTime? // set when CEU payment completes for external users; null = no active window
}

model Certification {
  id          String    @id @default(cuid())
  clerkUserId String
  issuedAt    DateTime
  expiresAt   DateTime
  renewedAt   DateTime? // set when the user renews their certification
  ceuPaidAt   DateTime? // set when the user pays for CEU renewal; cleared after renewal completes
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  emailLogs   EmailLog[]

  @@index([clerkUserId])
  @@index([expiresAt])
}

model EmailLog {
  id              String    @id @default(cuid())
  clerkUserId     String
  certificationId String
  type            String
  sentAt          DateTime  @default(now())
  clickedAt       DateTime? // set when user clicks the email CTA

  certification   Certification @relation(fields: [certificationId], references: [id], onDelete: Cascade)

  @@index([clerkUserId])
  @@index([certificationId])
  @@index([type])
  @@unique([certificationId, type])
}